{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "music-school-ots",
  "main": "cloudflare/worker.mjs",
  "compatibility_date": "2026-06-25",
  "compatibility_flags": [
    "nodejs_compat",
    "enable_nodejs_http_server_modules"
  ],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": true,
    "html_handling": "none"
  },
  "observability": {
    "enabled": true
  }
}
